{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SVN File Manager",
  "version": "0.1.0",
  "identifier": "com.svnfilemanager.svnfilemanager",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "SVN File Manager",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"],
    "resources": [],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true,
      "scope": [
        {
          "name": "svn",
          "cmd": "svn",
          "args": true
        }
      ]
    },
    "fs": {
      "scope": {
        "allow": ["$HOME/.svnfilemanager/**", "$APPDATA/**", "$LOCALAPPDATA/**"],
        "deny": []
      }
    },
    "clipboard-manager": {
      "all": true
    },
    "dialog": {
      "all": true
    },
    "notification": {
      "all": true
    }
  }
}
