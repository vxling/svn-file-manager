<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="SVNFileManager.App"
             xmlns:local="using:SVNFileManager"
             xmlns:vm="using:SVNFileManager.ViewModels"
             RequestedThemeVariant="Default">

    <Application.Resources>
        <vm:BoolToErrorBgConverter x:Key="BoolToErrorBgConverter"/>
        <vm:BoolToErrorFgConverter x:Key="BoolToErrorFgConverter"/>
    </Application.Resources>

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
  
    <Application.Styles>
        <FluentTheme />
    </Application.Styles>
</Application>
