<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SVNFileManager.ViewModels"
        xmlns:models="using:SVNFileManager.Models"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="700"
        x:Class="SVNFileManager.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="SVN File Manager"
        Width="1100"
        Height="700"
        MinWidth="900"
        MinHeight="550"
        WindowStartupLocation="CenterScreen"
        Background="#F0F4F8">

  <DockPanel>
    <!-- Top Toolbar -->
    <Border DockPanel.Dock="Top" Background="White" Padding="8,6" BoxShadow="0 1 3 #20000000">
      <Grid ColumnDefinitions="Auto,*,Auto">
        <!-- Left: Logo + Title -->
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
          <TextBlock Text="📁" FontSize="22"/>
          <TextBlock Text="SVN File Manager" FontSize="16" FontWeight="SemiBold" Foreground="#1A1A2E" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Center: Action Buttons -->
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
          <Button Command="{Binding RefreshCommand}" ToolTip.Tip="Refresh (F5)" Padding="10,6" Background="Transparent" BorderThickness="0">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="🔄" FontSize="14"/>
              <TextBlock Text="Refresh" Foreground="#444"/>
            </StackPanel>
          </Button>
          <Border Width="1" Background="#E0E0E0" Margin="6,4"/>
          <Button Command="{Binding SvnAddCommand}" ToolTip.Tip="Add unversioned files" Padding="10,6" Background="Transparent" BorderThickness="0">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="➕" FontSize="14"/>
              <TextBlock Text="Add" Foreground="#444"/>
            </StackPanel>
          </Button>
          <Button Command="{Binding CommitAllCommand}" ToolTip.Tip="Commit changes" Padding="10,6" Background="Transparent" BorderThickness="0">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="✓" FontSize="14" Foreground="#00A650"/>
              <TextBlock Text="Commit" Foreground="#444"/>
            </StackPanel>
          </Button>
          <Button Command="{Binding UpdateRepositoryCommand}" ToolTip.Tip="Update from repository" Padding="10,6" Background="Transparent" BorderThickness="0">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="⬇" FontSize="14"/>
              <TextBlock Text="Update" Foreground="#444"/>
            </StackPanel>
          </Button>
        </StackPanel>

        <!-- Right: Auto-commit -->
        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <CheckBox IsChecked="{Binding AutoCommitEnabled}" Content="Auto Commit" Foreground="#555"/>
          <TextBox Text="{Binding AutoCommitMessage}" Watermark="Commit message..." Width="140" Height="28" Background="White" BorderBrush="#D0D0D0"/>
        </StackPanel>
      </Grid>
    </Border>

    <!-- Bottom Status Bar -->
    <Border DockPanel.Dock="Bottom" Background="#1E88E5" Padding="12,6">
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Grid.Column="0" Text="{Binding CurrentPath}" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="16">
          <TextBlock Text="{Binding Files.Count, StringFormat='{}{0} items'}" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
          <TextBlock Text="•" Foreground="White" FontSize="12"/>
          <TextBlock Text="{Binding StatusText}" Foreground="White" FontSize="12" VerticalAlignment="Center" MaxWidth="300" TextTrimming="CharacterEllipsis"/>
        </StackPanel>
      </Grid>
    </Border>

    <!-- Main Content Area -->
    <Grid ColumnDefinitions="220,*">
      <!-- Left Sidebar: Repository List -->
      <Border Grid.Column="0" Background="White" Margin="8,8,4,8" CornerRadius="8" BoxShadow="0 1 5 #15000000">
        <DockPanel Margin="12">
          <!-- Header -->
          <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <Button DockPanel.Dock="Right" Command="{Binding AddRepositoryCommand}" ToolTip.Tip="Add repository" Padding="6" Background="#E3F2FD" CornerRadius="4">
              <TextBlock Text="+" FontSize="16" Foreground="#1E88E5"/>
            </Button>
            <TextBlock Text="Repositories" FontSize="14" FontWeight="SemiBold" Foreground="#1A1A2E" VerticalAlignment="Center"/>
          </DockPanel>

          <!-- Repository List -->
          <ListBox ItemsSource="{Binding Repositories}" SelectedItem="{Binding SelectedRepository}" Background="Transparent">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="models:Repository">
                <Border Padding="8,6" Margin="0,2" CornerRadius="4" Background="#F5F7FA">
                  <DockPanel>
                    <Button DockPanel.Dock="Right"
                            Command="{Binding $parent[ListBox].((vm:MainWindowViewModel)DataContext).RemoveRepositoryCommand}"
                            CommandParameter="{Binding}"
                            Padding="4" Background="#FFEBEE" CornerRadius="3"
                            ToolTip.Tip="Remove repository">
                      <TextBlock Text="✕" FontSize="11" Foreground="#E53935"/>
                    </Button>
                    <StackPanel>
                      <TextBlock Text="{Binding Name}" FontWeight="Medium" Foreground="#1A1A2E" FontSize="13"/>
                      <TextBlock Text="{Binding Path}" Foreground="#888" FontSize="10" TextTrimming="CharacterEllipsis" MaxLines="1"/>
                    </StackPanel>
                  </DockPanel>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </DockPanel>
      </Border>

      <!-- Right Area: File Browser -->
      <Border Grid.Column="1" Background="White" Margin="4,8,8,8" CornerRadius="8" BoxShadow="0 1 5 #15000000">
        <DockPanel Margin="0">
          <!-- Path Bar -->
          <Border DockPanel.Dock="Top" Background="#FAFBFC" Padding="12,10" BorderBrush="#E8E8E8" BorderThickness="0,0,0,1" CornerRadius="8,8,0,0">
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                <TextBlock Text="📂" FontSize="14" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding CurrentPath}" Foreground="#333" FontSize="13" VerticalAlignment="Center"/>
              </StackPanel>
              <Button Grid.Column="1" Command="{Binding RefreshCommand}" Background="Transparent" Padding="8,4" ToolTip.Tip="Refresh">
                <TextBlock Text="🔄" FontSize="13"/>
              </Button>
            </Grid>
          </Border>

          <!-- File List Header -->
          <Border DockPanel.Dock="Top" Background="#F5F7FA" Padding="12,6" BorderBrush="#E8E8E8" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="30,*,80,140">
              <TextBlock Grid.Column="0" Text="" Foreground="#888" FontSize="11" FontWeight="Medium"/>
              <TextBlock Grid.Column="1" Text="Name" Foreground="#888" FontSize="11" FontWeight="Medium" VerticalAlignment="Center"/>
              <TextBlock Grid.Column="2" Text="Size" Foreground="#888" FontSize="11" FontWeight="Medium" VerticalAlignment="Center"/>
              <TextBlock Grid.Column="3" Text="Modified" Foreground="#888" FontSize="11" FontWeight="Medium" VerticalAlignment="Center"/>
            </Grid>
          </Border>

          <!-- File List -->
          <ScrollViewer>
            <ListBox ItemsSource="{Binding Files}" SelectedItem="{Binding SelectedFile}" Background="Transparent" DoubleTapped="OnFileDoubleTapped">
              <ListBox.ItemTemplate>
                <DataTemplate x:DataType="models:FileItem">
                  <Border Padding="12,8" BorderBrush="#F0F0F0" BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="30,*,80,140">
                      <!-- Icon -->
                      <TextBlock Grid.Column="0" Text="{Binding IsDirectory, Converter={x:Static vm:BoolToIconConverter.Instance}}" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                      <!-- Name + SVN Status -->
                      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Border Background="{Binding SvnStatus, Converter={x:Static vm:SvnStatusToColorConverter.Instance}}" CornerRadius="3" Padding="4,2" MinWidth="20" HorizontalAlignment="Center">
                          <TextBlock Text="{Binding SvnStatus}" Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{Binding Name}" Foreground="#1A1A2E" FontSize="13" VerticalAlignment="Center"/>
                      </StackPanel>
                      <!-- Size -->
                      <TextBlock Grid.Column="2" Text="{Binding FileSize, Converter={x:Static vm:FileSizeConverter.Instance}}" Foreground="#666" FontSize="12" VerticalAlignment="Center"/>
                      <!-- Modified -->
                      <TextBlock Grid.Column="3" Text="{Binding LastModified, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Foreground="#888" FontSize="12" VerticalAlignment="Center"/>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </ScrollViewer>
        </DockPanel>
      </Border>
    </Grid>
  </DockPanel>
</Window>
