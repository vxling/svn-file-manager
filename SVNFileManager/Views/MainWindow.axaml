<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SVNFileManager.ViewModels"
        xmlns:models="using:SVNFileManager.Models"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="700"
        x:Class="SVNFileManager.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="SVN File Manager"
        Width="1200"
        Height="800"
        MinWidth="800"
        MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

  <Grid RowDefinitions="Auto,*,Auto">
    <!-- Toolbar -->
    <Border Grid.Row="0" Background="#FFFFFF" Padding="8" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
      <DockPanel>
        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
          <Button Command="{Binding RefreshCommand}" ToolTip.Tip="Refresh" Padding="12,6" Margin="2" Background="#E8E8E8">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="↻" FontSize="16" Foreground="#333333"/>
              <TextBlock Text="Refresh" Foreground="#333333" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>
          <Button Command="{Binding SvnAddCommand}" ToolTip.Tip="Add unversioned files" Padding="12,6" Margin="2" Background="#E8E8E8">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="+" FontSize="16" FontWeight="Bold" Foreground="#333333"/>
              <TextBlock Text="SVN Add" Foreground="#333333" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>
          <Button Command="{Binding CommitAllCommand}" ToolTip.Tip="Commit all changes" Padding="12,6" Margin="2" Background="#E8E8E8">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="✓" FontSize="16" Foreground="#00A650"/>
              <TextBlock Text="Commit" Foreground="#333333" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>
          <Button Command="{Binding UpdateRepositoryCommand}" ToolTip.Tip="Update" Padding="12,6" Margin="2" Background="#E8E8E8">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="↓" FontSize="16" Foreground="#333333"/>
              <TextBlock Text="Update" Foreground="#333333" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>
        </StackPanel>

        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
          <TextBlock Text="Auto:" Foreground="#333333" VerticalAlignment="Center" Margin="0,0,6,0"/>
          <CheckBox IsChecked="{Binding AutoCommitEnabled}" Foreground="#333333" VerticalAlignment="Center"/>
          <TextBox Text="{Binding AutoCommitMessage}" Watermark="Commit message" Width="150" Margin="8,0,0,0" VerticalAlignment="Center" Background="White" Foreground="#333333" BorderBrush="#CCCCCC"/>
        </StackPanel>

        <Border/>
      </DockPanel>
    </Border>

    <!-- Main Content -->
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="250" MinWidth="150"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <!-- Repository List Sidebar -->
      <Border Grid.Column="0" Background="#FFFFFF" Padding="8" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
        <DockPanel>
          <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
            <Button DockPanel.Dock="Right" Command="{Binding AddRepositoryCommand}" Padding="8,4" ToolTip.Tip="Add repository" Background="#E8E8E8">
              <TextBlock Text="+" FontSize="18" Foreground="#333333"/>
            </Button>
            <TextBlock Text="Repositories" Foreground="#333333" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
          </DockPanel>

          <ListBox ItemsSource="{Binding Repositories}" SelectedItem="{Binding SelectedRepository}" Background="#FAFAFA">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="models:Repository">
                <DockPanel Margin="4">
                  <Button DockPanel.Dock="Right"
                          Command="{Binding $parent[ListBox].((vm:MainWindowViewModel)DataContext).RemoveRepositoryCommand}"
                          CommandParameter="{Binding}"
                          Padding="4,2"
                          ToolTip.Tip="Remove"
                          Background="#E81123">
                    <TextBlock Text="×" FontSize="14" Foreground="White"/>
                  </Button>
                  <StackPanel>
                    <TextBlock Text="{Binding Name}" Foreground="#333333" FontWeight="Medium"/>
                    <TextBlock Text="{Binding Path}" Foreground="#888888" FontSize="10" TextTrimming="CharacterEllipsis"/>
                  </StackPanel>
                </DockPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </DockPanel>
      </Border>

      <!-- Splitter -->
      <GridSplitter Grid.Column="1" Width="4" Background="#E0E0E0"/>

      <!-- File List -->
      <Border Grid.Column="2" Background="#FFFFFF">
        <DockPanel>
          <!-- Path Bar -->
          <Border DockPanel.Dock="Top" Background="#FAFAFA" Padding="12,8" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <DockPanel>
              <TextBlock DockPanel.Dock="Right" Text="{Binding StatusText}" Foreground="#888888" FontSize="12" VerticalAlignment="Center" Margin="8,0"/>
              <TextBlock Text="{Binding CurrentPath}" Foreground="#333333" FontSize="13" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
            </DockPanel>
          </Border>

          <!-- File List -->
          <ListBox ItemsSource="{Binding Files}" SelectedItem="{Binding SelectedFile}" Background="White" DoubleTapped="OnFileDoubleTapped">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="models:FileItem">
                <Grid ColumnDefinitions="Auto,*,Auto,Auto" Margin="4,6">
                  <TextBlock Grid.Column="0" Text="{Binding SvnStatus}" Foreground="{Binding SvnStatus, Converter={x:Static vm:SvnStatusToColorConverter.Instance}}" FontWeight="Bold" FontSize="11" Width="24" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                  <TextBlock Grid.Column="1" Text="{Binding Name}" Foreground="#333333" VerticalAlignment="Center" FontSize="13" Margin="8,0"/>
                  <TextBlock Grid.Column="2" Text="{Binding FileSize, Converter={x:Static vm:FileSizeConverter.Instance}}" Foreground="#888888" FontSize="12" VerticalAlignment="Center" Width="80"/>
                  <TextBlock Grid.Column="3" Text="{Binding LastModified, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Foreground="#888888" FontSize="12" VerticalAlignment="Center" Width="140"/>
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </DockPanel>
      </Border>
    </Grid>

    <!-- Status Bar -->
    <Border Grid.Row="2" Background="#0078D4" Padding="8,4">
      <DockPanel>
        <TextBlock DockPanel.Dock="Right" Text="{Binding StatusText}" Foreground="White" FontSize="12"/>
        <TextBlock Text="{Binding Files.Count, StringFormat='{}{0} items'}" Foreground="White" FontSize="12"/>
      </DockPanel>
    </Border>
  </Grid>
</Window>
